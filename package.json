{
  "name": "rgteamspeak",
  "version": "1.0.0",
  "description": "Virtual pixel-art office with voice chat, screen sharing, and YouTube TV",
  "main": "electron.js",
  "author": "Rollergoose",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "electron": "electron .",
    "build": "electron-builder --win"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "express": "^4.21.0",
    "socket.io": "^4.7.0",
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.rollergoose.rgteamspeak",
    "productName": "RGTeamSpeak",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron.js",
      "preload.js",
      "server.js",
      "db.js",
      "public/**/*",
      "Resources/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "portable",
      "icon": "Resources/logo_v3_black.png"
    },
    "portable": {
      "artifactName": "RGTeamSpeak.exe"
    }
  }
}
